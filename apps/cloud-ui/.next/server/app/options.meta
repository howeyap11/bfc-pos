{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/options/layout,_N_T_/options/page,_N_T_/options"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/options/__PAGE__",
    "/options",
    "/_index",
    "/_head"
  ]
}
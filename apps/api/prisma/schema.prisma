generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id                     String                  @id @default("store_1")
  code                   String                  @unique
  name                   String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  auditLogs              AuditLog[]
  categories             Category[]
  ingredients            Ingredient[]
  ingredientStocks       IngredientStock[]
  inventoryCountSessions InventoryCountSession[]
  inventoryMovements     InventoryMovement[]
  inventoryUnits         InventoryUnit[]
  items                  Item[]
  localOutboxes          LocalOutbox[]
  menuBanners            MenuBanner[]
  menuItemRecipes        MenuItemRecipe[]
  menuItemRecipeSizes    MenuItemRecipeSize[]
  options                Option[]
  optionGroups           OptionGroup[]
  orders                 Order[]
  registerSessions       RegisterSession[]
  sopTemplates           SopTemplate[]
  staff                  Staff[]
  storeConfig            StoreConfig?
  tabs                   Tab[]
  tables                 Table[]
  transactions           Transaction[]
  zones                  Zone[]
}

model StoreConfig {
  id                    String   @id @default(cuid())
  storeId               String   @unique @default("store_1")
  enabledPaymentMethods String   @default("[\"CASH\",\"CARD\",\"GCASH\",\"FOODPANDA\"]")
  splitPaymentEnabled   Boolean  @default(true)
  paymentMethodOrder    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  store                 Store    @relation(fields: [storeId], references: [id])
}

model Staff {
  id        String   @id @default(cuid())
  storeId   String   @default("store_1")
  name      String
  passcode  String   @default("1000")
  key       String?  @unique
  role      String   @default("CASHIER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, name])
}

model Zone {
  id      String  @id @default(cuid())
  storeId String  @default("store_1")
  code    String
  name    String
  tables  Table[]
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@index([storeId])
}

model Table {
  id             String        @id @default(cuid())
  storeId        String        @default("store_1")
  zoneId         String
  label          String
  publicKey      String        @unique
  isActive       Boolean       @default(true)
  isFunctionRoom Boolean       @default(false)
  orders         Order[]
  tabs           Tab[]
  zone           Zone          @relation(fields: [zoneId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
  transactions   Transaction[]

  @@unique([zoneId, label])
  @@index([storeId])
  @@index([zoneId])
}

model Category {
  id       String   @id @default(cuid())
  storeId  String   @default("store_1")
  name     String   @unique
  prepArea PrepArea
  sort     Int      @default(0)
  store    Store    @relation(fields: [storeId], references: [id])
  items    Item[]

  @@index([storeId])
}

model Item {
  id                      String                @id @default(cuid())
  storeId                 String                @default("store_1")
  cloudId                 String?               @unique
  name                    String
  description             String?
  series                  String?
  basePrice               Int                   @default(0)
  isActive                Boolean               @default(true)
  isHidden                Boolean               @default(false)
  sort                    Int                   @default(0)
  foodpandaSurchargeCents Int                   @default(2000)
  defaultMilk             MilkType              @default(FULL_CREAM)
  supportsShots           Boolean               @default(false)
  isEspressoDrink         Boolean               @default(false)
  shotsPricingMode        ShotsPricingMode?
  defaultShots12oz        Int                   @default(0)
  defaultShots16oz        Int                   @default(0)
  shotsDefaultSource      ShotsDefaultSource    @default(MANUAL)
  defaultEspressoShots    Int                   @default(0)
  categoryId              String
  category                Category              @relation(fields: [categoryId], references: [id])
  store                   Store                 @relation(fields: [storeId], references: [id])
  images                  ItemImage[]
  itemOptionGroups        ItemOptionGroup[]
  menuItemRecipes         MenuItemRecipe[]
  menuItemRecipeSizes     MenuItemRecipeSize[]
  orderItems              OrderItem[]
  transactionLineItems    TransactionLineItem[]

  @@unique([categoryId, name])
  @@index([storeId])
  @@index([categoryId])
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  url       String
  isPrimary Boolean  @default(false)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([itemId, isPrimary])
}

model OptionGroup {
  id               String            @id @default(cuid())
  storeId          String            @default("store_1")
  name             String            @unique
  type             OptionGroupType
  minSelect        Int               @default(0)
  maxSelect        Int               @default(1)
  isRequired       Boolean           @default(false)
  sort             Int               @default(0)
  itemOptionGroups ItemOptionGroup[]
  options          Option[]
  store            Store             @relation(fields: [storeId], references: [id])

  @@index([storeId])
}

model Option {
  id               String            @id @default(cuid())
  storeId          String            @default("store_1")
  groupId          String
  name             String
  priceDelta       Int               @default(0)
  isDefault        Boolean           @default(false)
  sort             Int               @default(0)
  group            OptionGroup       @relation(fields: [groupId], references: [id])
  store            Store             @relation(fields: [storeId], references: [id])
  orderItemOptions OrderItemOption[]

  @@index([groupId])
  @@index([storeId])
}

model ItemOptionGroup {
  itemId  String
  groupId String
  group   OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  item    Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, groupId])
}

model Tab {
  id           String        @id @default(cuid())
  storeId      String        @default("store_1")
  type         TabType
  status       TabStatus     @default(OPEN)
  tableId      String
  quotaCents   Int           @default(300000)
  note         String?
  openedAt     DateTime      @default(now())
  closedAt     DateTime?
  orders       Order[]
  table        Table         @relation(fields: [tableId], references: [id])
  store        Store         @relation(fields: [storeId], references: [id])
  transactions Transaction[]

  @@index([storeId, status])
  @@index([tableId, status])
}

model Order {
  id            String        @id @default(cuid())
  storeId       String        @default("store_1")
  orderNo       Int
  status        OrderStatus   @default(PLACED)
  source        OrderSource   @default(QR_UNPAID)
  tableId       String
  tabId         String?
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(UNPAID)
  externalRef   String?
  customerNote  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tab           Tab?          @relation(fields: [tabId], references: [id])
  table         Table         @relation(fields: [tableId], references: [id])
  store         Store         @relation(fields: [storeId], references: [id])
  items         OrderItem[]
  transaction   Transaction?
  voidRequest   VoidRequest?

  @@index([storeId, createdAt])
  @@index([status])
  @@index([source])
  @@index([tabId])
}

model OrderItem {
  id        String            @id @default(cuid())
  orderId   String
  itemId    String
  qty       Int               @default(1)
  unitPrice Int               @default(0)
  lineNote  String?
  item      Item              @relation(fields: [itemId], references: [id])
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  options   OrderItemOption[]

  @@index([orderId])
  @@index([itemId])
}

model OrderItemOption {
  id          String    @id @default(cuid())
  orderItemId String
  optionId    String
  priceDelta  Int
  option      Option    @relation(fields: [optionId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([optionId])
}

model VoidRequest {
  id          String            @id @default(cuid())
  orderId     String            @unique
  status      VoidRequestStatus @default(PENDING)
  reason      String
  requestedAt DateTime          @default(now())
  requestedBy String?
  decidedAt   DateTime?
  decidedBy   String?
  managerNote String?
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MenuBanner {
  id        String    @id @default(cuid())
  storeId   String    @default("store_1")
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  isActive  Boolean   @default(true)
  sort      Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  store     Store     @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([isActive])
  @@index([sort])
}

model RegisterSession {
  id           String                @id @default(cuid())
  storeId      String                @default("store_1")
  status       RegisterSessionStatus @default(OPEN)
  openedAt     DateTime              @default(now())
  openedBy     String?
  openingCash  Int                   @default(0)
  closedAt     DateTime?
  closedBy     String?
  closingCash  Int?
  expectedCash Int?
  varianceCash Int?
  note         String?
  store        Store                 @relation(fields: [storeId], references: [id])
  transactions Transaction[]

  @@index([storeId, status])
  @@index([openedAt])
}

model Transaction {
  id                String                @id @default(cuid())
  storeId           String                @default("store_1")
  transactionNo     Int
  status            TransactionStatus     @default(PAID)
  source            TransactionSource     @default(POS)
  serviceType       ServiceType           @default(DINE_IN)
  registerSessionId String?
  orderId           String?               @unique
  tableId           String?
  tabId             String?
  subtotalCents     Int                   @default(0)
  discountCents     Int                   @default(0)
  serviceCents      Int                   @default(0)
  taxCents          Int                   @default(0)
  totalCents        Int                   @default(0)
  createdAt         DateTime              @default(now())
  createdBy         String?
  updatedAt         DateTime              @updatedAt
  voidedAt          DateTime?
  voidedBy          String?
  voidReason        String?
  tab               Tab?                  @relation(fields: [tabId], references: [id])
  table             Table?                @relation(fields: [tableId], references: [id])
  order             Order?                @relation(fields: [orderId], references: [id])
  registerSession   RegisterSession?      @relation(fields: [registerSessionId], references: [id])
  store             Store                 @relation(fields: [storeId], references: [id])
  lineItems         TransactionLineItem[]
  payments          TransactionPayment[]
  refunds           TransactionRefund[]

  @@unique([storeId, transactionNo])
  @@index([storeId, createdAt])
  @@index([registerSessionId])
  @@index([orderId])
  @@index([tableId])
  @@index([tabId])
}

model TransactionLineItem {
  id             String                  @id @default(cuid())
  transactionId  String
  itemId         String?
  name           String
  qty            Int                     @default(1)
  unitPrice      Int                     @default(0)
  modifiersCents Int                     @default(0)
  lineTotal      Int                     @default(0)
  note           String?
  isDrink        Boolean?
  serveVessel    String?
  optionsJson    String?
  item           Item?                   @relation(fields: [itemId], references: [id])
  transaction    Transaction             @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  refundItems    TransactionRefundItem[]

  @@index([transactionId])
  @@index([itemId])
}

model TransactionPayment {
  id            String                   @id @default(cuid())
  transactionId String
  method        PaymentMethod
  status        TransactionPaymentStatus @default(PAID)
  amountCents   Int
  refNo         String?
  receivedAt    DateTime                 @default(now())
  receivedBy    String?
  transaction   Transaction              @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([method])
}

model TransactionRefund {
  id                String                  @id @default(cuid())
  transactionId     String
  refundedByStaffId String?
  reason            String
  createdAt         DateTime                @default(now())
  transaction       Transaction             @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  refundItems       TransactionRefundItem[]

  @@index([transactionId])
}

model TransactionRefundItem {
  id                    String              @id @default(cuid())
  refundId              String
  transactionLineItemId String
  qtyRefunded           Int
  amountRefundedCents   Int
  transactionLineItem   TransactionLineItem @relation(fields: [transactionLineItemId], references: [id], onDelete: Cascade)
  refund                TransactionRefund   @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@index([transactionLineItemId])
}

model AuditLog {
  id        String      @id @default(cuid())
  storeId   String      @default("store_1")
  action    AuditAction
  entity    String?
  entityId  String?
  actorId   String?
  note      String?
  metaJson  String?
  createdAt DateTime    @default(now())
  store     Store       @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@index([entity, entityId])
}

model SopTemplate {
  id          String          @id @default(cuid())
  storeId     String          @default("store_1")
  name        String
  isActive    Boolean         @default(true)
  sort        Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  completions SopCompletion[]
  tasks       SopTask[]
  store       Store           @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, isActive])
}

model SopTask {
  id            String          @id @default(cuid())
  templateId    String
  title         String
  requiresPhoto Boolean         @default(false)
  sort          Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  completions   SopCompletion[]
  template      SopTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([templateId, sort])
}

model SopCompletion {
  id          String      @id @default(cuid())
  templateId  String
  taskId      String
  completedAt DateTime    @default(now())
  completedBy String?
  note        String?
  photoPath   String?
  task        SopTask     @relation(fields: [taskId], references: [id])
  template    SopTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId, completedAt])
  @@index([taskId, completedAt])
  @@index([completedAt])
}

model InventoryUnit {
  id                  String               @id @default(cuid())
  storeId             String               @default("store_1")
  code                String
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ingredients         Ingredient[]
  inventoryCountLines InventoryCountLine[]
  inventoryMovements  InventoryMovement[]
  store               Store                @relation(fields: [storeId], references: [id])
  menuItemRecipes     MenuItemRecipe[]
  menuItemRecipeSizes MenuItemRecipeSize[]

  @@unique([storeId, code])
  @@index([storeId])
}

model Ingredient {
  id                  String               @id @default(cuid())
  storeId             String               @default("store_1")
  sku                 String?
  name                String
  unitId              String
  reorderLevel        String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  unit                InventoryUnit        @relation(fields: [unitId], references: [id])
  store               Store                @relation(fields: [storeId], references: [id])
  stocks              IngredientStock?
  inventoryCountLines InventoryCountLine[]
  inventoryMovements  InventoryMovement[]
  menuItemRecipes     MenuItemRecipe[]
  menuItemRecipeSizes MenuItemRecipeSize[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([unitId])
  @@index([isActive])
}

model IngredientStock {
  id           String     @id @default(cuid())
  storeId      String     @default("store_1")
  ingredientId String     @unique
  onHandQty    String     @default("0")
  updatedAt    DateTime   @updatedAt
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  store        Store      @relation(fields: [storeId], references: [id])

  @@unique([storeId, ingredientId])
  @@index([storeId])
}

model MenuItemRecipe {
  id           String        @id @default(cuid())
  storeId      String        @default("store_1")
  menuItemId   String
  ingredientId String
  qtyPerItem   String
  unitId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  unit         InventoryUnit @relation(fields: [unitId], references: [id])
  ingredient   Ingredient    @relation(fields: [ingredientId], references: [id])
  item         Item          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  store        Store         @relation(fields: [storeId], references: [id])

  @@unique([storeId, menuItemId, ingredientId])
  @@index([storeId])
  @@index([menuItemId])
  @@index([ingredientId])
}

model MenuItemRecipeSize {
  id           String        @id @default(cuid())
  storeId      String        @default("store_1")
  menuItemId   String
  ingredientId String
  baseType     String
  sizeCode     String
  qtyPerItem   String
  unitId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  unit         InventoryUnit @relation(fields: [unitId], references: [id])
  ingredient   Ingredient    @relation(fields: [ingredientId], references: [id])
  item         Item          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  store        Store         @relation(fields: [storeId], references: [id])

  @@unique([storeId, menuItemId, ingredientId, baseType, sizeCode])
  @@index([storeId])
  @@index([menuItemId])
  @@index([ingredientId])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  storeId          String                @default("store_1")
  ingredientId     String
  type             InventoryMovementType
  qtyDelta         String
  unitId           String
  refType          String?
  refId            String?
  notes            String?
  createdByStaffId String?
  createdAt        DateTime              @default(now())
  unit             InventoryUnit         @relation(fields: [unitId], references: [id])
  ingredient       Ingredient            @relation(fields: [ingredientId], references: [id])
  store            Store                 @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, ingredientId, createdAt])
  @@index([refType, refId])
}

model InventoryCountSession {
  id                String               @id @default(cuid())
  storeId           String               @default("store_1")
  type              InventoryCountType
  status            InventoryCountStatus @default(DRAFT)
  startedAt         DateTime             @default(now())
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdByStaffId  String?
  approvedByStaffId String?
  lines             InventoryCountLine[]
  store             Store                @relation(fields: [storeId], references: [id])

  @@index([storeId, status])
  @@index([storeId, startedAt])
}

model InventoryCountLine {
  id             String                @id @default(cuid())
  countSessionId String
  ingredientId   String
  countedQty     String
  unitId         String
  notes          String?
  unit           InventoryUnit         @relation(fields: [unitId], references: [id])
  ingredient     Ingredient            @relation(fields: [ingredientId], references: [id])
  countSession   InventoryCountSession @relation(fields: [countSessionId], references: [id], onDelete: Cascade)

  @@unique([countSessionId, ingredientId])
  @@index([countSessionId])
  @@index([ingredientId])
}

model LocalOutbox {
  id          String            @id @default(cuid())
  storeId     String            @default("store_1")
  topic       String
  payloadJson String
  status      LocalOutboxStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  store       Store             @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
}

model CloudMenuItem {
  id                       String                   @id @default(cuid())
  cloudId                  String                   @unique
  storeId                  String                   @default("store_1")
  name                     String
  priceCents               Int
  isActive                 Boolean                  @default(true)
  imageUrl                 String?
  categoryCloudId          String?
  subCategoryCloudId       String?
  version                  Int
  deletedAt                DateTime?
  isDrink                  Boolean                  @default(false)
  serveVessel              String?
  defaultSizeId            String?
  defaultSizeOptionCloudId String?
  hasSizes                 Boolean                  @default(false)
  supportsShots            Boolean                  @default(false)
  defaultShots             Int?
  defaultSubstituteCloudId String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  sizes                    CloudMenuItemSize[]
  sizePrices               CloudMenuItemSizePrice[]

  @@index([storeId])
}

model CloudMenuItemSize {
  id              String        @id @default(cuid())
  cloudId         String        @unique
  storeId         String        @default("store_1")
  menuItemCloudId String
  label           String
  temp            String        @default("ANY")
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  menuItem        CloudMenuItem @relation(fields: [menuItemCloudId], references: [cloudId], onDelete: Cascade)

  @@index([storeId])
  @@index([menuItemCloudId])
}

model CloudMenuItemSizePrice {
  id                String        @id @default(cuid())
  cloudId           String        @unique
  storeId           String        @default("store_1")
  menuItemCloudId   String
  baseType          String
  sizeOptionCloudId String
  sizeCode          String
  priceCents        Int
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  menuItem          CloudMenuItem @relation(fields: [menuItemCloudId], references: [cloudId], onDelete: Cascade)

  @@unique([storeId, menuItemCloudId, baseType, sizeOptionCloudId])
  @@index([storeId])
  @@index([menuItemCloudId])
  @@index([sizeOptionCloudId])
}

model CloudCategory {
  id        String   @id @default(cuid())
  cloudId   String   @unique
  storeId   String   @default("store_1")
  name      String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model CloudSubCategory {
  id              String   @id @default(cuid())
  cloudId         String   @unique
  storeId         String   @default("store_1")
  name            String
  categoryCloudId String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([categoryCloudId])
}

model CloudMenuOptionGroup {
  id                   String   @id @default(cuid())
  cloudId              String   @unique
  storeId              String   @default("store_1")
  name                 String
  required             Boolean  @default(false)
  multi                Boolean  @default(false)
  isSizeGroup          Boolean  @default(false)
  defaultOptionCloudId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([storeId])
}

model CloudMenuOption {
  id           String   @id @default(cuid())
  cloudId      String   @unique
  storeId      String   @default("store_1")
  name         String
  priceDelta   Int      @default(0)
  groupCloudId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId])
  @@index([groupCloudId])
}

model CloudMenuOptionGroupSection {
  id                 String   @id @default(cuid())
  cloudId            String   @unique
  storeId            String   @default("store_1")
  optionGroupCloudId String
  key                String
  label              String
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([storeId])
  @@index([optionGroupCloudId])
}

model CloudMenuSize {
  id               String                      @id @default(cuid())
  cloudId          String                      @unique
  storeId          String                      @default("store_1")
  groupCloudId     String
  label            String
  sortOrder        Int                         @default(0)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  availability     CloudMenuSizeAvailability[]
  substitutePrices CloudSubstitutePrice[]

  @@index([storeId])
  @@index([groupCloudId])
}

model CloudMenuSizeAvailability {
  id          String        @id @default(cuid())
  cloudId     String        @unique
  storeId     String        @default("store_1")
  sizeCloudId String
  mode        String
  imageUrl    String?
  isEnabled   Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  size        CloudMenuSize @relation(fields: [sizeCloudId], references: [cloudId], onDelete: Cascade)

  @@unique([storeId, sizeCloudId, mode])
  @@index([storeId])
  @@index([sizeCloudId])
}

model CloudAddOn {
  id         String   @id @default(cuid())
  cloudId    String   @unique
  storeId    String   @default("store_1")

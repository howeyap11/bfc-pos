generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Single row (id=1): tracks current catalog version for sync
model CatalogVersion {
  id            Int @id @default(1)
  latestVersion Int @default(0)
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subCategories SubCategory[]
  items         MenuItem[]
}

enum DrinkTemp {
  HOT
  ICED
  ANY
}

enum DrinkMode {
  ICED
  HOT
  CONCENTRATED
}

model SubCategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  sortOrder  Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    MenuItem[]

  @@index([categoryId])
}

model MenuItem {
  id             String    @id @default(cuid())
  name           String
  priceCents     Int
  imageUrl       String?
  isActive       Boolean   @default(true)
  hasSizes       Boolean   @default(false)
  deletedAt      DateTime?
  sortOrder      Int       @default(0)
  version        Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  categoryId    String?
  subCategoryId String

  defaultSizeId         String?
  defaultSizeOptionId   String?      // MenuOption.id from "Sizes" group

  supportsShots Boolean  @default(false)
  defaultShots  Int?

  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subCategory SubCategory   @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  defaultSize MenuItemSize? @relation("MenuItemDefaultSize", fields: [defaultSizeId], references: [id], onDelete: SetNull)
  defaultSizeOption MenuOption? @relation("MenuItemDefaultSizeOption", fields: [defaultSizeOptionId], references: [id], onDelete: SetNull)

  recipeLines           RecipeLine[]
  recipeLinesBySize     RecipeLineSize[]
  optionGroupLinks      MenuItemOptionGroup[]
  addOnLinks            MenuItemAddOn[]
  substituteLinks       MenuItemSubstitute[]
  defaultSubstitute     Substitute?  @relation("MenuItemDefaultSubstitute", fields: [defaultSubstituteId], references: [id], onDelete: SetNull)
  defaultSubstituteId   String?      // legacy; use defaultSubstituteOptionId
  addOnGroupLinks       MenuItemAddOnGroup[]
  substituteGroupLinks  MenuItemSubstituteGroup[]
  defaultSubstituteOption SubstituteOption? @relation("MenuItemDefaultSubstituteOption", fields: [defaultSubstituteOptionId], references: [id], onDelete: SetNull)
  defaultSubstituteOptionId String?
  sizes                 MenuItemSize[]
  drinkSizeConfigs    MenuItemDrinkSizeConfig[]
  drinkModeDefaults   MenuItemDrinkModeDefault[]
  sizePrices          MenuItemSizePrice[]

  @@index([version])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([defaultSizeId])
  @@index([defaultSizeOptionId])
  @@index([defaultSubstituteId])
  @@index([defaultSubstituteOptionId])
}

model AddOn {
  id         String   @id @default(cuid())
  name       String
  priceCents Int      @default(0)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  recipeLines     AddOnRecipeLine[]
  menuItemLinks   MenuItemAddOn[]

  @@index([sortOrder])
}

model AddOnRecipeLine {
  id           String   @id @default(cuid())
  addOnId      String
  ingredientId String
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addOn      AddOn      @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([addOnId, ingredientId])
  @@index([addOnId])
  @@index([ingredientId])
}

model MenuItemAddOn {
  id      String @id @default(cuid())
  itemId  String
  addOnId String

  item  MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  addOn AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([itemId, addOnId])
  @@index([itemId])
  @@index([addOnId])
}

model Substitute {
  id         String   @id @default(cuid())
  name       String
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  recipeConsumption SubstituteRecipeConsumption[]
  menuItemLinks     MenuItemSubstitute[]
  asDefaultFor      MenuItem[] @relation("MenuItemDefaultSubstitute")
  prices            SubstitutePrice[]

  @@index([sortOrder])
}

model SubstitutePrice {
  id           String    @id @default(cuid())
  substituteId String
  sizeId       String
  mode         DrinkMode
  priceCents   Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  substitute Substitute @relation(fields: [substituteId], references: [id], onDelete: Cascade)
  size       MenuSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@unique([substituteId, sizeId, mode])
  @@index([substituteId])
  @@index([sizeId])
}

// Global recipe consumption matrix: per substitute × size × mode (ingredient + qty + unit)
model SubstituteRecipeConsumption {
  id           String    @id @default(cuid())
  substituteId String
  sizeId       String
  mode         DrinkMode
  ingredientId String
  qtyPerItem   Decimal   @db.Decimal(20, 10)
  unitCode     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  substitute Substitute @relation(fields: [substituteId], references: [id], onDelete: Cascade)
  size       MenuSize   @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([substituteId, sizeId, mode])
  @@index([substituteId])
  @@index([sizeId])
  @@index([ingredientId])
}

model MenuItemSubstitute {
  id           String   @id @default(cuid())
  itemId       String
  substituteId String

  item      MenuItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  substitute Substitute @relation(fields: [substituteId], references: [id], onDelete: Cascade)

  @@unique([itemId, substituteId])
  @@index([itemId])
  @@index([substituteId])
}

// Group-based Add-ons (primary architecture)
model AddOnGroup {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options        AddOnOption[]
  menuItemLinks  MenuItemAddOnGroup[]

  @@index([sortOrder])
}

model AddOnOption {
  id         String   @id @default(cuid())
  groupId    String
  name       String
  priceCents Int      @default(0)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group       AddOnGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recipeLines AddOnOptionRecipeLine[]

  @@index([groupId])
  @@index([sortOrder])
}

model AddOnOptionRecipeLine {
  id           String   @id @default(cuid())
  optionId     String
  ingredientId String
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  option     AddOnOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ingredient Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([optionId, ingredientId])
  @@index([optionId])
  @@index([ingredientId])
}

model MenuItemAddOnGroup {
  id      String @id @default(cuid())
  itemId  String
  groupId String

  item  MenuItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group AddOnGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([itemId, groupId])
  @@index([itemId])
  @@index([groupId])
}

// Group-based Substitutes (primary architecture)
model SubstituteGroup {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options        SubstituteOption[]
  menuItemLinks  MenuItemSubstituteGroup[]

  @@index([sortOrder])
}

model SubstituteOption {
  id         String   @id @default(cuid())
  groupId    String
  name       String
  priceCents Int      @default(0)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group       SubstituteGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recipeLines SubstituteOptionRecipeLine[]
  asDefaultFor MenuItem[] @relation("MenuItemDefaultSubstituteOption")

  @@index([groupId])
  @@index([sortOrder])
}

model SubstituteOptionRecipeLine {
  id           String   @id @default(cuid())
  optionId     String
  ingredientId String
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  option     SubstituteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ingredient Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([optionId, ingredientId])
  @@index([optionId])
  @@index([ingredientId])
}

model MenuItemSubstituteGroup {
  id      String @id @default(cuid())
  itemId  String
  groupId String

  item  MenuItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group SubstituteGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([itemId, groupId])
  @@index([itemId])
  @@index([groupId])
}

model MenuItemSize {
  id         String    @id @default(cuid())
  menuItemId String
  label      String
  temp       DrinkTemp @default(ANY)
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  asDefault MenuItem[] @relation("MenuItemDefaultSize")

  @@index([menuItemId])
  @@unique([menuItemId, label, temp])
}

model MenuItemDrinkSizeConfig {
  id         String    @id @default(cuid())
  menuItemId String
  mode       DrinkMode
  optionId   String
  isEnabled  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  option   MenuOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, mode, optionId])
  @@index([menuItemId])
  @@index([optionId])
}

model MenuItemDrinkModeDefault {
  id               String    @id @default(cuid())
  menuItemId       String
  mode             DrinkMode
  defaultOptionId  String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  option   MenuOption @relation(fields: [defaultOptionId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, mode])
  @@index([menuItemId])
  @@index([defaultOptionId])
}

model MenuItemSizePrice {
  id           String    @id @default(cuid())
  menuItemId   String
  baseType     DrinkMode
  sizeOptionId String
  sizeCode     String
  priceCents   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  option   MenuOption @relation(fields: [sizeOptionId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, baseType, sizeOptionId])
  @@index([menuItemId])
  @@index([sizeOptionId])
}

model MenuOptionGroup {
  id               String       @id @default(cuid())
  name             String
  required         Boolean      @default(false)
  multi            Boolean      @default(false)
  defaultOptionId  String?

  isSizeGroup           Boolean @default(false)
  isSystem              Boolean @default(false)
  isDeletable           Boolean @default(true)
  trackRecipeConsumption Boolean @default(false)

  items          MenuItemOptionGroup[]
  options        MenuOption[]
  sections       MenuOptionGroupSection[]
  defaultOption  MenuOption?   @relation("GroupDefaultOption", fields: [defaultOptionId], references: [id], onDelete: SetNull)

  @@index([defaultOptionId])
}

model MenuOptionGroupSection {
  id            String  @id @default(cuid())
  optionGroupId String
  key           String
  label         String
  sortOrder     Int     @default(0)
  isSystem      Boolean @default(false)
  isDeletable   Boolean @default(true)

  optionGroup MenuOptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@unique([optionGroupId, key])
  @@index([optionGroupId])
}

model MenuOption {
  id         String @id @default(cuid())
  name       String
  priceDelta Int    @default(0)
  sortOrder  Int    @default(0)

  groupId String
  group   MenuOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  asDefaultSize           MenuItem[]          @relation("MenuItemDefaultSizeOption")
  drinkSizeConfigs        MenuItemDrinkSizeConfig[]
  drinkModeDefaults       MenuItemDrinkModeDefault[]
  sizePrices              MenuItemSizePrice[]
  asDefaultForGroups      MenuOptionGroup[]   @relation("GroupDefaultOption")
  recipeLines             OptionChoiceRecipeLine[]

  @@index([groupId])
}

model OptionChoiceRecipeLine {
  id           String   @id @default(cuid())
  optionId     String
  ingredientId String
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  option     MenuOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ingredient Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([optionId, ingredientId])
  @@index([optionId])
  @@index([ingredientId])
}

model MenuItemOptionGroup {
  id      String @id @default(cuid())
  itemId  String
  groupId String

  item  MenuItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group MenuOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([itemId, groupId])
  @@index([itemId])
  @@index([groupId])
}

model ShotPricingRule {
  id                 String   @id @default(cuid())
  name               String   @default("Standard")
  shotsPerBundle     Int      @default(2)
  priceCentsPerBundle Int     @default(4000)
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TransactionTypeSetting {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String
  priceDeltaCents Int      @default(0)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Single-row store settings (id=1)
model StoreSetting {
  id         String   @id @default("1")
  adminPinHash String?
  updatedAt  DateTime @updatedAt
}

// Synced from POS for Cloud Admin reporting
model SyncedTransaction {
  id                   String    @id @default(cuid())
  storeId              String
  sourceTransactionId  String    @unique // POS transaction id (idempotency)
  transactionNo        Int
  status               String    // PAID | VOID
  source               String    @default("POS") // POS, QR, etc.
  serviceType          String    @default("DINE_IN")
  cashierName          String?
  totalCents           Int
  subtotalCents        Int       @default(0)
  discountCents        Int       @default(0)
  itemsCount           Int       @default(0)
  paymentsJson         String    // JSON array of { method, amountCents }
  lineItemsSummaryJson String?   // JSON array of { name, qty, lineTotal } for display
  createdAt            DateTime
  voidedAt             DateTime?
  voidReason           String?

  @@index([storeId])
  @@index([storeId, createdAt])
}

// POS devices - one per physical mini PC
model Device {
  id          String   @id @default(cuid())
  storeId     String   @default("store_1")
  name        String   // e.g. "Café POS 1"
  deviceKey   String   @unique // secret for polling auth; owner copies to POS .env
  lastSeenAt  DateTime?
  posVersion  String?  // reported by POS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commands DeviceCommand[]

  @@index([storeId])
}

enum DeviceCommandType {
  UPDATE_POS
  RESTART_POS
  FORCE_SYNC
}

enum DeviceCommandStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model DeviceCommand {
  id          String            @id @default(cuid())
  deviceId    String
  type        DeviceCommandType
  status      DeviceCommandStatus @default(PENDING)
  errorMessage String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([deviceId, status])
}

model IngredientCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients Ingredient[]
}

enum InventoryDepartment {
  BAR
  KITCHEN
  PASTRY
  SHARED
}

enum InventoryTrackingType {
  VOLATILE
  EXACT
  COUNT_ONLY
}

enum InventoryLocationType {
  WAREHOUSE
  STORE
  EVENT
  POPUP
}

enum StockMovementType {
  OPENING
  SALE_DEDUCTION
  PURCHASE_ADD
  WASTE
  TRANSFER_OUT
  TRANSFER_IN
  RECONCILIATION_VARIANCE
  MANUAL_ADJUSTMENT
  REVERSAL
}

enum StockTransferStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum InventoryReconciliationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum WasteReasonCode {
  SPILL
  REMAKE
  EXPIRED
  DAMAGED
  TESTING
  OTHER
}

model InventoryLocation {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  locationType InventoryLocationType
  isActive     Boolean               @default(true)
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  stockMovements     StockMovement[]
  stockTransfersFrom StockTransfer[] @relation("TransferFrom")
  stockTransfersTo   StockTransfer[] @relation("TransferTo")
  reconciliations    InventoryReconciliation[]

  @@index([locationType])
}

model Ingredient {
  id                    String    @id @default(cuid())
  name                  String
  unitCode              String
  isActive              Boolean   @default(true)
  categoryId            String?
  sortOrder             Int       @default(0)
  imageUrl              String?
  deletedAt             DateTime?
  version               Int
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Inventory metadata (optional for backward compat)
  department            InventoryDepartment?
  trackingType          InventoryTrackingType? @default(EXACT)
  quickCountUnitName    String?
  quickCountUnitToBase  Decimal?  @db.Decimal(20, 10)
  warehouseUnitName     String?
  warehouseUnitToBase   Decimal?  @db.Decimal(20, 10)

  category              IngredientCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipeLines           RecipeLine[]
  recipeLinesSize       RecipeLineSize[]
  optionChoiceRecipeLines   OptionChoiceRecipeLine[]
  addOnRecipeLines          AddOnRecipeLine[]
  substituteRecipeConsumptions SubstituteRecipeConsumption[]
  addOnOptionRecipeLines    AddOnOptionRecipeLine[]
  substituteOptionRecipeLines SubstituteOptionRecipeLine[]
  stockMovements        StockMovement[]
  stockTransferLines      StockTransferLine[]
  reconciliationLines     InventoryReconciliationLine[]

  @@index([version])
  @@index([categoryId, sortOrder])
  @@index([categoryId])
  @@index([department])
  @@index([trackingType])
}

model StockMovement {
  id                    String            @id @default(cuid())
  ingredientId          String
  locationId            String
  movementType          StockMovementType
  quantityDeltaBaseUnit Decimal           @db.Decimal(20, 10)
  sourceType            String?
  sourceId              String?
  actorStaffId          String?
  approvedByStaffId     String?
  notes                 String?
  businessDate          DateTime?
  createdAt             DateTime          @default(now())

  ingredient Ingredient         @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  location   InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([sourceType, sourceId])
  @@index([ingredientId, locationId])
  @@index([locationId])
  @@index([createdAt])
}

model StockTransfer {
  id                 String              @id @default(cuid())
  fromLocationId     String
  toLocationId       String
  submittedByStaffId String?
  approvedByStaffId  String?
  status             StockTransferStatus @default(DRAFT)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  fromLocation InventoryLocation @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  lines        StockTransferLine[]

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
}

model StockTransferLine {
  id              String        @id @default(cuid())
  stockTransferId String
  ingredientId    String
  quantityInput   Decimal       @db.Decimal(20, 10)
  quantityBase    Decimal       @db.Decimal(20, 10)
  notes           String?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([stockTransferId])
  @@index([ingredientId])
}

model InventoryReconciliation {
  id                String                       @id @default(cuid())
  locationId        String
  businessDate      DateTime
  countedByStaffId  String?
  approvedByStaffId String?
  status            InventoryReconciliationStatus @default(DRAFT)
  notes             String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  location InventoryLocation             @relation(fields: [locationId], references: [id], onDelete: Restrict)
  lines    InventoryReconciliationLine[]

  @@unique([locationId, businessDate])
  @@index([locationId])
  @@index([businessDate])
}

model InventoryReconciliationLine {
  id                  String    @id @default(cuid())
  reconciliationId    String
  ingredientId        String
  theoreticalQtyBase  Decimal   @db.Decimal(20, 10)
  actualQtyBase       Decimal   @db.Decimal(20, 10)
  varianceQtyBase     Decimal   @db.Decimal(20, 10)
  varianceReasonCode  String?
  notes               String?

  reconciliation InventoryReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  ingredient      Ingredient             @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, ingredientId])
  @@index([reconciliationId])
  @@index([ingredientId])
}

// Menu Settings: expandable for Sizes, future modifiers, etc.
model MenuSettingGroup {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  isSystem    Boolean @default(false)
  isDeletable Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuSizes   MenuSize[]
}

model MenuSize {
  id         String   @id @default(cuid())
  groupId    String
  label      String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group                  MenuSettingGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  availability           MenuSizeAvailability[]
  substitutePrices       SubstitutePrice[]
  substituteRecipeConsumptions SubstituteRecipeConsumption[]

  @@index([groupId])
}

model MenuSizeAvailability {
  id        String    @id @default(cuid())
  mode      DrinkMode
  sizeId    String
  imageUrl  String?
  isEnabled Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  size MenuSize @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@unique([mode, sizeId])
  @@index([mode])
  @@index([sizeId])
}

model RecipeLine {
  id           String   @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  deletedAt    DateTime?
  version      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@index([version])
}

model RecipeLineSize {
  id           String   @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  baseType     DrinkMode
  sizeCode     String
  qtyPerItem   Decimal  @db.Decimal(20, 10)
  unitCode     String
  deletedAt    DateTime?
  version      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([menuItemId, ingredientId, baseType, sizeCode])
  @@index([menuItemId])
  @@index([ingredientId])
  @@index([version])
}
